@page
@model Acme.Draw.Web.Pages.EntriesModel

<h1>Entries</h1>

<table class="table table-striped table-sm">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Serial</th>
            <th>Submitted</th>
        </tr>
    </thead>
    <tbody>
@foreach (var e in Model.Entries)
{
        <tr>
            <td>@e.FirstName @e.LastName</td>
            <td>@e.Email</td>
            <td>@e.SerialNumber</td>
            <td>@e.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
        </tr>
}
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        @if (Model.PageNumber > 1)
        {
            <a asp-page="/Entries" asp-route-PageNumber="@(Model.PageNumber - 1)">Previous</a>
        }

        <span> Page @Model.PageNumber of @Model.TotalPages </span>

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a asp-page="/Entries" asp-route-PageNumber="@(Model.PageNumber + 1)">Next</a>
        }
    </nav>
}